# ============================================================================
# .gitignore for Algo-Trade
# Sections by scope: General / AI / Backend / CLI.
# ============================================================================

# ----- General (all modules) -----------------------------------------------
# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
# Virtual environments
.venv/
venv/
env/
# Secrets and environment files
.env
*.env
# Jupyter
.ipynb_checkpoints/
# OS junk
.DS_Store
Thumbs.db
# IDE / editor
.idea/
.vscode/
*.swp

# ----- AI (ai/) ------------------------------------------------------------
# Regenerated internals, do NOT commit
ai/dev_models/*
!ai/dev_models/.gitkeep
ai/data_store/*
!ai/data_store/.gitkeep


# ----- Backend (backend/) --------------------------------------------------
# SQLite databases and cached market data
*.db
*.sqlite
*.sqlite3
data/
# Local config with secrets (the tracked template is config/settings.example.yaml)
config/settings.yaml

# ----- CLI (cli/ : React / Vite / Node) ------------------------------------
node_modules/
cli/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*